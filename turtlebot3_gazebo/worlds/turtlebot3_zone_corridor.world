<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <shadows>false</shadows>
      <ambient>0.76 0.76 0.76 1.0</ambient>
      <background>0.95 0.95 0.94 1.0</background>
    </scene>

    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose frame=''>0.0 0.0 12.0 0 1.52 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <physics type="ode">
      <real_time_update_rate>0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>0</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- Room: 8m x 3m corridor -->
    <model name='zone_corridor_layout'>
      <static>true</static>

      <link name='top_wall'>
        <pose>0 1.5 0 0 0 0</pose>
        <collision name='collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>8.0 0.15 0.6</size></box></geometry>
        </collision>
        <visual name='visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>8.0 0.15 0.6</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1.0</ambient>
            <diffuse>0.65 0.65 0.68 1.0</diffuse>
          </material>
        </visual>
      </link>

      <link name='bottom_wall'>
        <pose>0 -1.5 0 0 0 0</pose>
        <collision name='collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>8.0 0.15 0.6</size></box></geometry>
        </collision>
        <visual name='visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>8.0 0.15 0.6</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1.0</ambient>
            <diffuse>0.65 0.65 0.68 1.0</diffuse>
          </material>
        </visual>
      </link>

      <link name='left_wall'>
        <pose>-4.0 0 0 0 0 1.5708</pose>
        <collision name='collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>3.15 0.15 0.6</size></box></geometry>
        </collision>
        <visual name='visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>3.15 0.15 0.6</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1.0</ambient>
            <diffuse>0.65 0.65 0.68 1.0</diffuse>
          </material>
        </visual>
      </link>

      <link name='right_wall'>
        <pose>4.0 0 0 0 0 1.5708</pose>
        <collision name='collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>3.15 0.15 0.6</size></box></geometry>
        </collision>
        <visual name='visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry><box><size>3.15 0.15 0.6</size></box></geometry>
          <material>
            <ambient>0.65 0.65 0.68 1.0</ambient>
            <diffuse>0.65 0.65 0.68 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Goal marker -->
    <model name='goal_marker'>
      <static>true</static>
      <pose>3.5 -0.5 0 0 0 0</pose>
      <link name='marker'>
        <visual name='pad_visual'>
          <pose>0 0 0.003 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.38</radius><length>0.006</length></cylinder>
          </geometry>
          <material>
            <ambient>0.18 0.72 0.24 1.0</ambient>
            <diffuse>0.18 0.72 0.24 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Barrel in danger zone -->
    <model name='barrel_zone'>
      <static>true</static>
      <pose>1.0 0.8 0 0 0 0</pose>
      <link name='body'>
        <collision name='collision'>
          <pose>0 0 0.25 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.20</radius><length>0.50</length></cylinder>
          </geometry>
        </collision>
        <visual name='visual'>
          <pose>0 0 0.25 0 0 0</pose>
          <geometry>
            <cylinder><radius>0.20</radius><length>0.50</length></cylinder>
          </geometry>
          <material>
            <ambient>0.85 0.45 0.10 1.0</ambient>
            <diffuse>0.85 0.45 0.10 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Red danger-zone floor marker (upper side of corridor) -->
    <model name='danger_zone_marker'>
      <static>true</static>
      <pose>1.0 0.9 0 0 0 0</pose>
      <link name='zone'>
        <visual name='zone_visual'>
          <pose>0 0 0.003 0 0 0</pose>
          <geometry>
            <box><size>4.0 1.0 0.006</size></box>
          </geometry>
          <transparency>0.28</transparency>
          <material>
            <ambient>1.0 0.10 0.10 1.0</ambient>
            <diffuse>1.0 0.10 0.10 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
