        </collision>
        <visual name='left_block_visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>2.1 0.18 0.6</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
        <pose>-0.75 -0.7 0 0 0 1.5708</pose>
      </link>

      <link name='mid_block'>
        <collision name='mid_block_collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>2.1 0.18 0.6</size>
            </box>
          </geometry>
        </collision>
        <visual name='mid_block_visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
