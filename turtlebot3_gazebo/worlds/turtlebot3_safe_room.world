    <model name='goal_guard_zone'>
      <static>true</static>
      <pose>2.0 0.55 0 0 0 0</pose>
      <link name='zone'>
        <visual name='zone_visual'>
          <pose>0 0 0.003 0 0 0</pose>
          <geometry>
            <box>
              <size>1.15 0.95 0.006</size>
            </box>
          </geometry>
          <transparency>0.3</transparency>
          <material>
            <ambient>1.0 0.12 0.12 1.0</ambient>
