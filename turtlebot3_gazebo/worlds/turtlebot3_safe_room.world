<?xml version="1.0"?>
<sdf version="1.6">
  <world name="default">

    <include>
      <uri>model://ground_plane</uri>
    </include>

    <include>
      <uri>model://sun</uri>
    </include>

    <scene>
      <shadows>false</shadows>
      <ambient>0.75 0.75 0.75 1.0</ambient>
      <background>0.95 0.95 0.95 1.0</background>
    </scene>

    <gui fullscreen='0'>
      <camera name='user_camera'>
        <pose frame=''>0.15 0.0 12.0 0 1.52 0</pose>
        <view_controller>orbit</view_controller>
        <projection_type>perspective</projection_type>
      </camera>
    </gui>

    <physics type="ode">
      <real_time_update_rate>0</real_time_update_rate>
      <max_step_size>0.001</max_step_size>
      <real_time_factor>0</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <precon_iters>0</precon_iters>
          <sor>1.400000</sor>
          <use_dynamic_moi_rescaling>1</use_dynamic_moi_rescaling>
        </solver>
        <constraints>
          <cfm>0.00001</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>2000.000000</contact_max_correcting_vel>
          <contact_surface_layer>0.01000</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <model name='room_shell'>
      <static>true</static>

      <link name='top_wall'>
        <collision name='top_wall_collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>7.0 0.15 0.6</size>
            </box>
          </geometry>
        </collision>
        <visual name='top_wall_visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>7.0 0.15 0.6</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
        <pose>0 2.25 0 0 0 0</pose>
      </link>

      <link name='bottom_wall'>
        <collision name='bottom_wall_collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>7.0 0.15 0.6</size>
            </box>
          </geometry>
        </collision>
        <visual name='bottom_wall_visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>7.0 0.15 0.6</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
        <pose>0 -2.25 0 0 0 0</pose>
      </link>

      <link name='left_wall'>
        <collision name='left_wall_collision'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>4.6 0.15 0.6</size>
            </box>
          </geometry>
        </collision>
        <visual name='left_wall_visual'>
          <pose>0 0 0.3 0 0 0</pose>
          <geometry>
            <box>
              <size>4.6 0.15 0.6</size>
            </box>
          </geometry>
          <material>
            <script>
              <uri>file://media/materials/scripts/gazebo.material</uri>
              <name>Gazebo/Wood</name>
