            </script>
            <ambient>1 1 1 1</ambient>
          </material>
        </visual>
        <pose>0.85 0.7 0 0 0 1.5708</pose>
      </link>
    </model>

    <model name='human_upper_turn'>
      <static>true</static>
      <pose>-0.05 1.05 0 0 0 0</pose>
      <link name='body'>
        <collision name='body_collision'>
          <pose>0 0 0.45 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.17</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name='body_visual'>
          <pose>0 0 0.45 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.17</radius>
              <length>0.9</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.25 0.5 0.9 1.0</ambient>
            <diffuse>0.25 0.5 0.9 1.0</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name='human_goal_guard'>
      <static>true</static>
      <pose>2.0 0.55 0 0 0 0</pose>
      <link name='body'>
        <collision name='body_collision'>
          <pose>0 0 0.45 0 0 0</pose>
          <geometry>
            <cylinder>
              <radius>0.17</radius>
